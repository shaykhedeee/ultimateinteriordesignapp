# Copy this file to .env and add freshly rotated keys.
# Do not commit .env. Keys pasted into chat should be treated as exposed and rotated.

PORT=8787
NODE_ENV=development

# Optional deployment guard. Leave blank for local-only development.
# Set in production and send Authorization: Bearer <token> or X-Studio-Key: <token> for API calls.
STUDIO_ACCESS_TOKEN=

# Image generation provider priority:
# library-reuse, gemini-imagen, huggingface, freepik, openai, pollinations, pexels, curated, mock.
# Smart-cost keeps library reuse first and uses live generation only when needed.
IMAGE_PROVIDER=library-reuse
IMAGE_PROVIDER_FALLBACKS=gemini-imagen,huggingface,freepik,openai-gpt-image-1,openai,pollinations,pexels,curated,mock
LIVE_IMAGE_GEN=true
AI_SPEND_MODE=smart-cost
RENDER_REUSE_THRESHOLD=86
MAX_AUTO_RENDER_VARIANTS=2

# OpenAI image generation
# Must be an OpenAI Platform key. OpenRouter keys belong in OPENROUTER_API_KEY.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=high

# Freepik image generation
FREEPIK_API_KEY=
FREEPIK_IMAGE_ENDPOINT=https://api.freepik.com/v1/ai/text-to-image/flux-dev
FREEPIK_ASPECT_RATIO=widescreen_16_9

# Optional precision render path for future Flux/ControlNet adapters
REPLICATE_API_TOKEN=
BFL_API_KEY=
CONTROLNET_MODEL=
DEFAULT_RENDER_VARIANTS=4

# Stock image search fallback
PEXELS_API_KEY=
PEXELS_PER_PAGE=3

# Gemini text/vision and image generation.
# Use GEMINI_IMAGE_MODEL=gemini-2.5-flash-image for native Gemini image generation.
# Use GEMINI_IMAGE_MODEL=imagen-4.0-generate-001 only when Imagen API access is enabled for the key/project.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_PROMPT_REFINEMENT=true
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_NATIVE_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_IMAGE_ASPECT_RATIO=16:9
GEMINI_IMAGE_COUNT=1
GEMINI_IMAGE_SIZE=1K

# Optional research/model keys for future enrichment
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
GROQ_API_KEY=
AIMLAPI_KEY=
GOOGLE_AI_STUDIO_KEY_1=
GOOGLE_AI_STUDIO_KEY_2=
HUGGINGFACE_API_KEY=
HUGGINGFACE_IMAGE_MODELS=black-forest-labs/FLUX.1-schnell
HUGGINGFACE_IMAGE_ENDPOINT_BASE=https://router.huggingface.co/hf-inference/models
HUGGINGFACE_IMAGE_WIDTH=1280
HUGGINGFACE_IMAGE_HEIGHT=720
HUGGINGFACE_STEPS=28
HUGGINGFACE_GUIDANCE=3.5

# Zero-cost public draft-render fallback. Use for exploration, not guaranteed final client quality.
POLLINATIONS_ENABLED=true
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_IMAGE_WIDTH=1280
POLLINATIONS_IMAGE_HEIGHT=720
POLLINATIONS_IMAGE_BASE=https://image.pollinations.ai/prompt
POLLINATIONS_API_KEY=
