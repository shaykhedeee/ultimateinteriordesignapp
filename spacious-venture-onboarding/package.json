{
  "name": "spacious-venture-experience-centre",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite --config vite.config.js --host 127.0.0.1",
    "server": "node server/index.js",
    "build": "vite build frontend",
    "studio:build": "vite build frontend",
    "studio:preflight": "node server/scripts/preflight.js",
    "website:preview": "npx http-server public-website -p 8090",
    "start": "node server/index.js",
    "seed": "node server/data/seed.js",
    "preflight": "node server/scripts/preflight.js",
    "import:references": "node server/data/import-pexels-references.js",
    "check": "npm run build && node server/data/seed.js"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@vitejs/plugin-react": "^5.0.0",
    "better-sqlite3": "^11.10.0",
    "canvas": "^3.2.3",
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "exceljs": "^3.4.0",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "openai": "^6.39.0",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.0",
    "test": "^3.3.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
