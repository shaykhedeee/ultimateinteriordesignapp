# =====================================================================
# THE ULTIMATE INTERIOR DESIGN APPLICATION - ENVIRONMENT TEMPLATE
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# NEVER commit real secrets. Keep `.env` restricted (chmod 600 / not shared).
# All var names below are the exact names the server reads via process.env.*
# =====================================================================

# Frontend API base override (optional). The built frontend defaults to
# http://127.0.0.1:8787 (matching PORT above). Set this only if you run the
# backend on a different host/port or deploy it. Defined at build time.
VITE_API_URL=http://127.0.0.1:8787

PORT=8787

# -- Image generation provider priority --
# Primary provider, then comma-separated fallbacks.
# NOTE: if your OPENAI_API_KEY is an OpenRouter key (starts sk-or-v1-), the
# OpenAI image path is auto-skipped by design. Prefer gemini-imagen as primary
# when a real Gemini key is present; it is correctly detected and used.
IMAGE_PROVIDER=gemini-imagen
IMAGE_PROVIDER_FALLBACKS=openai-gpt-image-1,openai,freepik,huggingface,stability-sdxl,stability-flux,pollinations,pexels,curated,mock
AI_SPEND_MODE=smart-cost
RENDER_REUSE_THRESHOLD=86
MAX_AUTO_RENDER_VARIANTS=2
LIVE_IMAGE_GEN=true

# -- OpenAI image generation --
# OPTIONAL. Live image generation works WITHOUT an OpenAI key via Freepik /
# HuggingFace / Imagine.Art (already configured and active). Add a native
# OpenAI key (starts sk-proj-) here only if you want DALL-E / GPT-image-1.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=high

# -- Freepik image generation --
FREEPIK_API_KEY=
FREEPIK_WEBHOOK_SECRET=
FREEPIK_IMAGE_ENDPOINT=https://api.freepik.com/v1/ai/text-to-image/flux-dev
FREEPIK_ASPECT_RATIO=widescreen_16_9

# -- Stock image search fallback --
PEXELS_API_KEY=
PEXELS_PER_PAGE=3

# -- Vision Board image generation --
IMAGINE_ART_API_KEY=

# -- Google / Gemini (AI Studio keys) --
# server reads GEMINI_API_KEY, GOOGLE_API_KEY, GOOGLE_AI_STUDIO_KEY_1/2
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_AI_STUDIO_KEY_1=
GOOGLE_AI_STUDIO_KEY_2=
GEMINI_TEXT_MODEL=gemini-flash-latest
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
GEMINI_IMAGE_ASPECT_RATIO=16:9
GEMINI_IMAGE_COUNT=1
GEMINI_IMAGE_SIZE=1K

# -- HuggingFace --
HUGGINGFACE_API_KEY=

# -- Ollama (local LLM) --
OLLAMA_API_KEY=
OLLAMA_HOST=http://localhost:11434

# -- OpenRouter / Groq / Perplexity / AimlAPI --
OPENROUTER_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
AIMLAPI_KEY=

# -- Future integrations (NO current consumer in code yet; stored for readiness) --
GITHUB_TOKEN=
RESEND_API_KEY=

# -- Optional alt providers (disabled) --
POLLINATIONS_ENABLED=false
