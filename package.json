{
  "name": "ultimate-interior-design-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ULTIDA — Ultimate Interior Design OS (Node ESM backend + Vite React frontend)",
  "scripts": {
    "start": "node server/index.js",
    "install:server": "cd server && npm install",
    "server": "node --env-file=.env server/index.js",
    "client": "vite --config frontend/vite.config.mjs",
    "frontend": "vite --config frontend/vite.config.mjs",
    "dev": "node --env-file=.env server/index.js",
    "build": "node scripts/build-frontend.mjs",
    "seed": "node server/database/seed.js",
    "launch": "node scripts/launch.mjs",
    "lint": "eslint frontend/src server --ext js,jsx",
    "check": "node --check server/index.js",
    "test": "node tests/test-runner.mjs",
    "test:screens": "node scripts/screen-render-smoke.mjs",
    "test:e2e": "playwright test tests/e2e --config tests/e2e/playwright.config.mjs",
    "preflight": "node scripts/preflight.mjs",
    "pipeline": "node scripts/dev-cli.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^4.2.0",
    "archiver": "^6.0.1",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.3.0",
    "bullmq": "^5.79.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.23.0",
    "multer": "^2.2.0",
    "nanoid": "^5.0.7",
    "openai": "^6.45.0",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.26.0",
    "tailwindcss": "^4.0.0",
    "three": "^0.185.1",
    "zustand": "^5.0.14",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.0.0",
    "playwright": "^1.61.1",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
