{
  "name": "ultimate-interior-design-application",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ULTIDA — Ultimate Interior Design OS (Node ESM backend + Vite React frontend)",
  "scripts": {
    "start": "node server/index.js",
    "server": "node --env-file=.env server/index.js",
    "frontend": "vite",
    "dev": "node --env-file=.env server/index.js",
    "build": "vite build",
    "test": "node --test tests/*.test.js",
    "test:screens": "node scripts/screen-render-smoke.mjs",
    "test:e2e": "playwright test tests/e2e --config tests/e2e/playwright.config.mjs",
    "preflight": "node scripts/preflight.mjs",
    "pipeline": "node scripts/dev-cli.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "archiver": "^6.0.1",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "lucide-react": "^0.400.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "openai": "^4.56.0",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "tailwindcss": "^4.0.0",
    "three": "^0.167.0",
    "vite": "^5.4.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "playwright": "^1.61.1"
  }
}
